# Pooled Neon connection used by the running FastAPI application.
DATABASE_URL=postgresql://USER:PASSWORD@EP-ID-pooler.REGION.aws.neon.tech/swarm_ai_qa?sslmode=require

# Direct Neon connection used only by Alembic migrations.
DATABASE_DIRECT_URL=postgresql://USER:PASSWORD@EP-ID.REGION.aws.neon.tech/swarm_ai_qa?sslmode=require

DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE_SECONDS=300

# Local FastAPI checkpoint store. Used until the API factory is wired to NeonRunStore.
SWARM_SQLITE_PATH=.data/swarm-ai-qa.db

# Optional for explicitly allowlisted private repositories only.
# Use a fine-grained token with Contents: read only.
GITHUB_TOKEN=
# Comma-separated canonical IDs, for example: github:OWNER/REPO,github:ORG/OTHER
SWARM_GITHUB_ALLOWED_PRIVATE_REPOSITORIES=
GITHUB_API_URL=https://api.github.com
GITHUB_TIMEOUT_SECONDS=15

# Browser artifacts remain outside the evaluated target repository.
SWARM_ARTIFACT_ROOT=.data/artifacts
